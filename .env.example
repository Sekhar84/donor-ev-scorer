# ═══════════════════════════════════════════════════════════════════════════
# donor-ev-scorer — environment variable template
# ───────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# RULES:
#   .env         → NEVER commit (in .gitignore)
#   .env.example → ALWAYS commit (no real values, just structure)
#
# BelFund is used as the demo client throughout this project.
# Replace CLIENT_ID and CLIENT_NAME with your actual values in .env.
# ═══════════════════════════════════════════════════════════════════════════

# ── Client and campaign identity ──────────────────────────────────────────
CLIENT_ID=47                      # integer client identifier (BelFund demo = 47)
CLIENT_NAME=BelFund               # human-readable label for logs and reports
CAMPAIGN_TYPE=FID                 # FID (Fidelization/loyalty) | REAC (Reactivation)
CAMPAIGN_CHANNEL=Direct Mail

# ── Data paths ────────────────────────────────────────────────────────────
# Leave blank when using simulated data (SIM_MODE=true)
DATA_DIR=                         # path to raw SAS/CSV data files
INPUT_DIR=                        # path to input Excel files (scope, REFNIS)
OUTPUT_DIR=                       # path to write model outputs and scored files

# ── Simulation mode ───────────────────────────────────────────────────────
# Set SIM_MODE=true to use synthetic data instead of real data.
# All SIM_* parameters are ignored when SIM_MODE=false.
SIM_MODE=true
SIM_N_DONORS=15000                # number of synthetic donors to generate
SIM_N_CAMPAIGNS=19                # number of synthetic campaigns
SIM_SEED=42                       # random seed for full reproducibility

# ── Modelling parameters ──────────────────────────────────────────────────
RESPONSE_CAP_PCT=0.90             # percentile to cap amount target (train only)
LOW_RR_THRESHOLD=0.03             # campaigns below this RR excluded from training
ACTIVE_THRESHOLD_DAYS=730         # max days since last gift for FID eligibility
LAPSED_18M_DAYS=548               # threshold for lapsed donor flag (~18 months)
FRAC_TRAIN=0.70                   # train split fraction (time-based, campaign-level)
FRAC_VAL=0.15                     # validation split fraction
FRAC_TEST=0.15                    # test split fraction
RANDOM_SEED=42

# ── Scoring and selection parameters ─────────────────────────────────────
COST_PER_MAIL=1.50                # default cost per mailed piece (€)
# FID selection: donor selected if EV > COST_PER_MAIL
# REAC selection: top EV_DECILE_CUTOFF deciles selected
EV_DECILE_CUTOFF=3                # for REAC campaigns: select top N deciles by EV

# ── API ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=80
API_VERSION=1.0
MODEL_VERSION=v1

# ── MLflow experiment tracking ────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=belfund-ev-scorer-fid

# ── AWS — fill in only when deploying to cloud (Day 4+) ───────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=                # never hardcode — use IAM roles in production
AWS_SECRET_ACCESS_KEY=            # never hardcode — use IAM roles in production
S3_BUCKET=                        # bucket name for data and model artifacts
ECR_REPO=                         # ECR repository URI for Docker images
EC2_KEY_NAME=                     # EC2 key pair name for SSH access
